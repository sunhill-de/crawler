{
	"name" : "sunhill-de/crawler",
	"description" : "A php file crawler that sorts and categorizes files.",
	"keywords" : [
		"application",
		"file management",
		"console",
		"php",
		"cli"
	],
	"homepage" : "https://github.com/sunhill-de/crawler",
	"type" : "project",
	"license" : "MIT",
	"authors" : [{
			"name" : "Klaus Dimde",
			"email" : "klaus@metalhorde.de"
		}
	],
	"repositories": [
		{
			"type":"vcs",
			"url":"https://github.com/sunhill-de/basic.git",
			"reference":"stable"		
		},
		{
			"type":"git",
			"url":"https://github.com/sunhill-de/ORM.git"
		}
	],
	"require" : {
		"php": "^7.3|^8.0",
		"illuminate/database": "^8.40",
		"laravel-zero/framework": "^8.8",
		"sunhill/basic":"dev-main",
		"sunhill/orm":"dev-main"
	},
	"require-dev" : {
		"fakerphp/faker": "^1.9.1",
		"mockery/mockery": "^1.4.3",
		"pestphp/pest": "^1.3"
	},
	"autoload" : {
		"psr-4" : {
			"App\\" : "app/",
			"Sunhill\\Crawler\\" : "lib/"
		}
	},
	"autoload-dev" : {
		"psr-4" : {
			"Tests\\" : "tests/"
		}
	},
	"config" : {
		"preferred-install" : "dist",
		"sort-packages" : true,
		"optimize-autoloader" : true
	},
	"minimum-stability" : "dev",
	"prefer-stable" : true,
	"bin" : [
		"crawler"
	]
}
